+// Just the gaussian-surface halo representation(s) in the protein subtree —
+// "the cloud". We fade only these, leaving the cartoon ribbons and hemes solid.
+function cloudReprs(plugin: PluginUIContext, ctx: ViewerCtx) {
+  return plugin.state.data
+    .select(
+      StateSelection.Generators.ofType(
+        PluginStateObject.Molecule.Structure.Representation3D,
+        ctx.protein.structure.ref
+      )
+    )
+    .filter((cell) => (cell.transform.params as any)?.type?.name === "gaussian-surface")
+    .map((cell) => cell.obj?.data?.repr)
+    .filter(Boolean) as { setState: (s: { alphaFactor: number }) => void }[];
+}
+
+// requestAnimationFrame tween. Resolves early if `isStale` flips (a newer scene
+// started, or we unmounted), leaving whatever value the last frame set.
+function tween(
+  durationMs: number,
+  onFrame: (t: number) => void,
+  isStale: () => boolean
+) {
+  return new Promise<void>((resolve) => {
+    const start = performance.now();
+    const step = (now: number) => {
+      if (isStale()) return resolve();
+      const t = Math.min(1, (now - start) / durationMs);
+      onFrame(t);
+      if (t < 1) requestAnimationFrame(step);
+      else resolve();
+    };
+    requestAnimationFrame(step);
+  });
+}
+
+// Animate the cloud (halo) opacity via its representation's multiplicative
+// alphaFactor — leaving the ribbons and hemes untouched. `opacityRef` tracks
+// the current factor across transitions so an interrupted fade resumes from
+// where it was.
+async function fadeCloud(
+  plugin: PluginUIContext,
+  ctx: ViewerCtx,
+  to: number,
+  durationMs: number,
+  opacityRef: { current: number },
+  isStale: () => boolean
+) {
+  const reprs = cloudReprs(plugin, ctx);
+  if (!reprs.length) {
+    opacityRef.current = to;
+    return;
+  }
+  const from = opacityRef.current;
+  if (Math.abs(from - to) < 1e-3) {
+    for (const r of reprs) r.setState({ alphaFactor: to });
+    plugin.canvas3d?.requestDraw();
+    opacityRef.current = to;
+    return;
+  }
+  await tween(
+    durationMs,
+    (t) => {
+      const eased = t * t * (3 - 2 * t); // smoothstep
+      const f = from + (to - from) * eased;
+      opacityRef.current = f;
+      for (const r of reprs) r.setState({ alphaFactor: f });
+      plugin.canvas3d?.requestDraw();
+    },
+    isStale
+  );
+}
